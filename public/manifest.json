{
  "manifest_version": 3,
  "name": "书签整理器",
  "version": "1.0.0",
  "description": "整理和浏览你的书签，支持多种视图、搜索和随机发现。",
  "permissions": [
    "bookmarks",
    "history",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "打开书签整理器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
